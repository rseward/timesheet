# Test Dockerfile with alternative registries for local testing
# This is a simplified version to test the build process

FROM registry.access.redhat.com/ubi9/nodejs-20 AS frontend-builder

# Set working directory
WORKDIR /app/frontend

# Copy frontend package files
COPY frontend/web/package*.json ./
USER 0
RUN npm ci --only=production

# Copy frontend source code
COPY frontend/web/ ./

# Build the Vue.js application
RUN npm run build

FROM registry.access.redhat.com/ubi9/python-311 AS backend-builder

USER 0
# Install uv
RUN pip install uv

# Set working directory
WORKDIR /app/backend

# Copy backend requirements
COPY backend/requirements.txt ./

# Install Python dependencies using uv
RUN uv pip install --system -r requirements.txt

FROM registry.access.redhat.com/ubi9/python-311 AS runtime

USER 0
# Install nginx and supervisor
RUN microdnf install -y nginx supervisor && microdnf clean all

# Create app user
RUN useradd --create-home --shell /bin/bash app

# Set working directory
WORKDIR /app

# Copy Python dependencies from builder
COPY --from=backend-builder /usr/local/lib/python3.11/site-packages /usr/local/lib/python3.11/site-packages
COPY --from=backend-builder /usr/local/bin /usr/local/bin

# Copy backend source code
COPY --chown=app:app backend/ ./backend/

# Copy built frontend from frontend-builder
COPY --from=frontend-builder --chown=app:app /app/frontend/dist ./frontend/web/dist/

# Copy source code for container build reference
COPY --chown=app:app . ./src/

# Create necessary directories
RUN mkdir -p /data /var/log/supervisor /var/log/nginx

# Copy nginx configuration
COPY docker/nginx.conf /etc/nginx/nginx.conf

# Copy supervisor configuration
COPY docker/supervisord.conf /etc/supervisor/conf.d/supervisord.conf

# Copy startup script
COPY docker/start.sh /start.sh
RUN chmod +x /start.sh

# Set environment variables
ENV TIMESHEET_SQLITE=/data/timesheet.sqlite
ENV TIMESHEET_SRC_HOME=/app/src
ENV TIMESHEET_SA_URL=sqlite:///data/timesheet.sqlite
ENV PYTHONPATH=/app/backend

# Expose port
EXPOSE 80

# Set user
USER app

# Start the application
CMD ["/start.sh"]